# ============================================================================
# EdgeFirst Perception Schemas — Doxygen Configuration
# ============================================================================
# This file is a template processed by `make docs` to produce build/docs/html
# and build/docs/man output. Version-sensitive fields are substituted from
# Cargo.toml at configure time.

PROJECT_NAME           = "EdgeFirst Perception Schemas"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "Zero-copy CDR message schemas for ROS2-compatible middleware"
PROJECT_LOGO           =

OUTPUT_DIRECTORY       = build/docs
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English

BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
INLINE_INHERITED_MEMB  = YES
FULL_PATH_NAMES        = NO
TAB_SIZE               = 4
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
GROUP_NESTED_COMPOUNDS = NO
INLINE_SIMPLE_STRUCTS  = NO
TYPEDEF_HIDES_STRUCT   = NO

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = NO
EXTRACT_ANON_NSPACES   = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = NO
HIDE_IN_BODY_DOCS      = NO
INTERNAL_DOCS          = NO
CASE_SENSE_NAMES       = YES
HIDE_SCOPE_NAMES       = NO
HIDE_COMPOUND_REFERENCE= NO
SHOW_HEADERFILE        = YES
SHOW_INCLUDE_FILES     = YES
SHOW_GROUPED_MEMB_INC  = NO
FORCE_LOCAL_INCLUDES   = NO
INLINE_INFO            = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = NO
SORT_MEMBERS_CTORS_1ST = NO
SORT_GROUP_NAMES       = NO
SORT_BY_SCOPE_NAME     = NO

GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = NO
GENERATE_BUGLIST       = NO
GENERATE_DEPRECATEDLIST= YES
SHOW_USED_FILES        = YES
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO
WARN_FORMAT            = "$file:$line: $text"

# Input — point at the two public headers. Leave the Rust source and internal
# detail headers out; they're implementation, not API.
INPUT                  = include/edgefirst/schemas.h \
                         include/edgefirst/schemas.hpp \
                         README.md \
                         CAPI.md \
                         CONTRIBUTING.md \
                         ARCHITECTURE.md \
                         CODE_OF_CONDUCT.md \
                         SECURITY.md

USE_MDFILE_AS_MAINPAGE = README.md

# Exclude the vendored stdlib backports from the generated docs — they're
# implementation detail, not part of the public API surface users should
# browse. Similarly, exclude the `edgefirst::schemas::detail` namespace via
# EXCLUDE_SYMBOLS.
EXCLUDE                = include/edgefirst/stdlib \
                         tests \
                         examples \
                         target \
                         build \
                         venv

EXCLUDE_PATTERNS       = */tests/* */examples/* */target/* */build/*

EXCLUDE_SYMBOLS        = edgefirst::schemas::detail \
                         edgefirst::schemas::detail::* \
                         edgefirst::stdlib \
                         edgefirst::stdlib::*

FILE_PATTERNS          = *.h *.hpp *.md
RECURSIVE              = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = NO
REFERENCES_RELATION    = NO
REFERENCES_LINK_SOURCE = YES

ALPHABETICAL_INDEX     = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = AUTO_LIGHT
HTML_DYNAMIC_SECTIONS  = NO
HTML_INDEX_NUM_ENTRIES = 100
GENERATE_TREEVIEW      = YES
ENUM_VALUES_PER_LINE   = 4
TREEVIEW_WIDTH         = 250

DISABLE_INDEX          = NO

GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = YES
MAN_OUTPUT             = man
MAN_EXTENSION          = .3
MAN_LINKS              = YES

GENERATE_XML           = NO
GENERATE_DOCBOOK       = NO

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = include

HAVE_DOT               = NO
GENERATE_LEGEND        = NO

QUIET                  = NO
